project_id          = "your-gcp-project"
region              = "europe-west1"
service_name        = "converge-runtime"
repository_id       = "converge"
runtime_image_name  = "converge-runtime"
runtime_image_tag   = "latest"
firebase_project_id = "your-gcp-project"

plain_env_vars = {
  RUST_LOG = "info"
}

secret_env_vars = {
  OPENAI_API_KEY = {
    secret_id = "converge-openai-api-key"
    version   = "latest"
  }
  ANTHROPIC_API_KEY = {
    secret_id = "converge-anthropic-api-key"
    version   = "latest"
  }
}
